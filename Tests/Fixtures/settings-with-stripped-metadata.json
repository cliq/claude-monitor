      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude-monitor/hook.sh SessionStart" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude-monitor/hook.sh UserPromptSubmit" }
